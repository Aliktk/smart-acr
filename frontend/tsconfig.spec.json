{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": "src",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "declaration": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "src/components/forms/form-templates.spec.tsx",
    "src/components/forms/FormB_S121E.tsx",
    "src/components/forms/FormC_Inspector.tsx",
    "src/components/forms/FormD_Superintendent.tsx",
    "src/components/forms/FormE_CarDriversDespatchRiders.tsx",
    "src/components/forms/FormF_Per1718Officers.tsx",
    "src/components/forms/FormPrimitives.tsx",
    "src/components/forms/templateFieldSchemas.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".test-dist"
  ]
}
