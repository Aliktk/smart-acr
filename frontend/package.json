{
  "name": "@smart-acr/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/restart-dev.mjs next dev --port 3000",
    "dev:frontend": "node ../scripts/restart-dev.mjs next dev --port 3000",
    "clean": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\"",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "next lint",
    "typecheck": "node -e \"require('fs').rmSync('.next/types',{ recursive: true, force: true }); require('fs').mkdirSync('.next',{ recursive: true })\" && next typegen && tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.spec.json && node -e \"require('fs').mkdirSync('.test-dist',{ recursive: true }); require('fs').writeFileSync('.test-dist/package.json', JSON.stringify({ type: 'commonjs' }))\" && node .test-dist/components/forms/form-templates.spec.js"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-query-devtools": "^5.69.0",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.487.0",
    "next": "^15.2.3",
    "playwright-core": "^1.59.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
