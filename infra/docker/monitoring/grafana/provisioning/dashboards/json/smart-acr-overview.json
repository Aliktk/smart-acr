      "targets": [
        {
          "expr": "rate(smart_acr_http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "5xx/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } },
        "overrides": []
      }
    },
