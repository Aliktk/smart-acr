NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://smartacr:replace-with-strong-db-password@postgres:5432/smart_acr?schema=public
POSTGRES_DB=smart_acr
POSTGRES_USER=smartacr
POSTGRES_PASSWORD=replace-with-strong-db-password
JWT_ACCESS_SECRET=replace-with-64-char-random-secret
JWT_REFRESH_SECRET=replace-with-64-char-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
WEB_ORIGIN=https://acr.fia.gov.pk
STORAGE_PATH=/var/lib/smart-acr/storage
FORGOT_PASSWORD_ENABLED=false
FORGOT_PASSWORD_TOKEN_TTL_MINUTES=30
