# Backend environment — GCP VM testing
# Copy to: infra/docker/env/backend.gcp.env
# Then fill in every value marked CHANGE_ME.

NODE_ENV=production
PORT=4000

# ── Database ─────────────────────────────────────────────────────────────────
# "postgres" is the Docker service name — do NOT change the hostname.
DATABASE_URL=postgresql://smartacr:CHANGE_ME_DB_PASSWORD@postgres:5432/smart_acr?schema=public
POSTGRES_DB=smart_acr
POSTGRES_USER=smartacr
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_64CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64CHARS
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Use the GCP VM external IP (no trailing slash).
WEB_ORIGIN=http://34.44.76.159

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PATH=/var/lib/smart-acr/storage

# ── Features ──────────────────────────────────────────────────────────────────
FORGOT_PASSWORD_ENABLED=false
FORGOT_PASSWORD_TOKEN_TTL_MINUTES=30
